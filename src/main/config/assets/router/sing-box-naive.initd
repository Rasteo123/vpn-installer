#!/bin/sh /etc/rc.common

USE_PROCD=1
START=92
STOP=05

CONF=/etc/sing-box/naive-client.json

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/sing-box run -c "$CONF"
    procd_set_param respawn 5 10 5
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}

reload_service() {
    procd_send_signal sing-box-naive '*' HUP
}
